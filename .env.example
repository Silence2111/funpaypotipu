# ──────────────────────────────────────────────────────────────
# GameMarket — пример конфигурации. Скопируйте в .env и заполните.
# ──────────────────────────────────────────────────────────────

# Среда
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://gamemarket:gamemarket@localhost:5432/gamemarket?schema=public

# Redis (кэш / очереди / pub-sub)
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
API_URL=http://localhost:4000

# Web (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Auth / JWT (сгенерируйте свои секреты: openssl rand -base64 48)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Шифрование чувствительных данных (envelope encryption KEK)
DATA_ENCRYPTION_KEY=change-me-32-bytes-base64

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gamemarket

# Поиск (Meilisearch). Если MEILI_URL пуст — поиск на Postgres (fallback).
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=change-me

# Платежи
PAYMENT_PROVIDER=mock
MOCK_WEBHOOK_SECRET=dev-webhook-secret

# Таймеры сделок и выплаты (мс / дни)
ORDER_AUTO_CONFIRM_TTL_MS=259200000   # 72ч — авто-подтверждение после выдачи
ORDER_PAYMENT_TTL_MS=1800000          # 30мин — авто-истечение неоплаченного
ORDER_SWEEP_INTERVAL_MS=60000         # период прогона таймеров
PAYOUT_NEWBIE_HOLD_DAYS=3             # холд выплат для новичков

# Почта (локально — MailHog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=no-reply@gamemarket.local
